 <exercise>
  <p>Write out the boundary conditions mathematically from each graph.
    <ol>
      <li> <p> <m>   </m>

        <figure xml:id="fig-sector-insulation">
          <caption>Boundary conditions of Steady-State temperature <m>u(r,\theta)</m> on a sector plate  </caption>
            <image width="80%" alignment="center">
              <latex-image>  
                  \begin{tikzpicture}[scale=4]

                  % Axes
                  \draw[->] (-0.05,0) -- (1.2,0) node[right] {$x$};
                  \draw[->] (0,-0.05) -- (0,1) node[above] {$y$};

                  % Dashed line y = x
                  \draw[dashed] (0,0) -- ({1.1*cos(45)},{1.1*sin(45)})
                    node[above right] {$y=x$};

                  % Parameters
                  \def\rinner{0.5}
                  \def\router{1}
                  \def\ang{45}

                  % --- Filled region ---
                  \fill[orange!60]
                    (\rinner,0)
                    arc[start angle=0, end angle=\ang, radius=\rinner]
                    -- ({\router*cos(\ang)},{\router*sin(\ang)})
                    arc[start angle=\ang, end angle=0, radius=\router]
                    -- cycle;

                  % --- Boundary curves ---
                  % r=1 (insulated)
                  \draw[thick,blue]
                    (\router,0) arc[start angle=0, end angle=\ang, radius=\router];

                  % r=1/2
                  \draw[thick]
                    (\rinner,0) arc[start angle=0, end angle=\ang, radius=\rinner];

                  % theta = 0
                  \draw[thick]
                    (0.5,0) -- (1,0);

                  % theta = pi/4
                  \draw[thick]
                    ({0.5*cos(45)},{0.5*sin(45)})
                    -- ({1*cos(45)},{1*sin(45)});

                  % --- Insulation ticks on r=1 ---
                  \foreach \t in {5,10,...,40} {
                    \draw
                      ({\router*cos(\t)},{\router*sin(\t)})
                      -- ({1.05*cos(\t)},{1.05*sin(\t)});
                  }

                  % --- Labels ---
                  \node at (0.8,-0.05) {$u=0$ at $\theta=0$};

                  \node at ({0.75*cos(45)-0.05},{0.75*sin(45)+.1}) {$u=0$};

                  \node[right] at ({1.05*cos(25)},{1.05*sin(25)})
                    {insulated at $r=1$};

                  \node[left] at ({0.52*cos(25)},{0.43*sin(25)})
                    {$u=u_0$ at $r=\tfrac12$};

                  \end{tikzpicture}    
                </latex-image>
              </image>
            </figure>
      </p></li>
      <li>  <p> <m>  </m>

        <figure xml:id="fig-quarter-insulation">
          <caption>Boundary conditions of Steady-State temperature <m>u(r,\theta)</m> on a quarter plate  </caption>
            <image width="80%" alignment="center">
              <latex-image>  
                    \begin{tikzpicture}[scale=1.8]

                  % Axes
                  \draw[->, thick] (0,0) -- (2.4,0) node[right] {$x$};
                  \draw[->, thick] (0,0) -- (0,2.4) node[above] {$y$};

                  % Parameters
                  \def\rinner{1}
                  \def\router{2}

                  % Filled region (quarter annulus)
                  \fill[orange!60]
                    (\rinner,0)
                    arc[start angle=0, end angle=90, radius=\rinner]
                    -- (0,\router)
                    arc[start angle=90, end angle=0, radius=\router]
                    -- cycle;

                  % Outer boundary r=2
                  \draw[thick, blue]
                    (0,\router) arc[start angle=90, end angle=0, radius=\router];

                  % Inner boundary r=1
                  \draw[thick]
                    (0,\rinner) arc[start angle=90, end angle=0, radius=\rinner];

                  % Insulated vertical boundary (y-axis)
                  \draw[thick] (0,1) -- (0,2);
                  \foreach \y in {1.05,1.15,...,1.95} {
                    \draw (-0.12,\y) -- (0,\y+0.1);
                  }

                  % Insulated horizontal boundary (x-axis)
                  \draw[thick] (1,0) -- (2,0);
                  \foreach \x in {1.05,1.15,...,1.95} {
                    \draw (\x,-0.12) -- (\x+0.1,0);
                  }

                  % Labels
                  \node at (0.6,0.6) {$u=0$ at $r=1$};
                  \node at (1.55,1.55) {$u=f(\theta)$ at $r=2$};

                  \node[left] at (-0.05,1.5) {insulated};
                  \node[below] at (1.5,-0.15) {insulated};

                  \end{tikzpicture}
                </latex-image>
              </image>
            </figure>         
        </p>   </li>

       <li>   <p>    <m>  </m>

          <figure xml:id="fig-cylinder">
          <caption>Boundary conditions of Steady-State temperature <m>u(r,\theta)</m> on a cylinder.  </caption>
            <image width="80%" alignment="center">
              <latex-image>
                  \begin{tikzpicture}[scale=1]

                        % Parameters
                        \def\R{2}
                        \def\H{4}
                        \def\el{0.6}     % ellipse vertical scaling

                        % ----- Cylinder body (fill) -----
                        % Side wall
                        \fill[blue!25, opacity=0.7]
                          (-\R,0) --
                          (\R,0) --
                          (\R,\H) --
                          (-\R,\H) -- cycle;

                        % Bottom disk
                        \fill[blue!20, opacity=0.6]
                          (-\R,0) arc[start angle=180, end angle=360,
                            x radius=\R, y radius=\el] --
                          (\R,0) arc[start angle=0, end angle=180,
                            x radius=\R, y radius=\el] -- cycle;

                        % Top disk
                        \fill[blue!30, opacity=0.7]
                          (-\R,\H) arc[start angle=180, end angle=360,
                            x radius=\R, y radius=\el] --
                          (\R,\H) arc[start angle=0, end angle=180,
                            x radius=\R, y radius=\el] -- cycle;

                        % ----- Cylinder outlines -----
                        % Bottom ellipse
                        \draw[thick]
                          (-\R,0) arc[start angle=180, end angle=360,
                            x radius=\R, y radius=\el];
                        \draw[thick,dashed]
                          (\R,0) arc[start angle=0, end angle=180,
                            x radius=\R, y radius=\el];

                        % Top ellipse
                        \draw[thick]
                          (-\R,\H) arc[start angle=180, end angle=360,
                            x radius=\R, y radius=\el];
                        \draw[thick]
                          (\R,\H) arc[start angle=0, end angle=180,
                            x radius=\R, y radius=\el];

                        % Side edges
                        \draw[thick] (-\R,0) -- (-\R,\H);
                        \draw[thick] (\R,0) -- (\R,\H);

                        % ----- Axes -----
                        % Center dashed axis
                        \draw[dashed] (0,0) -- (0,\H);

                        % z-axis
                        \draw[->, thick] (0,\H+0.2) -- (0,\H+1) node[above] {$z$};

                        % x- and y-axes at base
                        \draw[->, thick] (0,0) -- (-2.6,-0.8) node[left] {$x$};
                        \draw[->, thick] (0,0) -- (2.8,0) node[right] {$y$};

                        % Tick marks on center axis
                        \foreach \z in {1,2,3} {
                          \draw (-0.1,\z) -- (0.1,\z);
                        }

                        % ----- Labels -----
                        \node at (1.2,4.8) {$u=u_0$ at $z=4$};
                        \node[right] at (2.1,2) {$u=0$ at $r=2$};
                        \node at (-.5,-.9) {$u=0$ at $z=0$};

                        \end{tikzpicture}
                                        

                </latex-image>
              </image>
            </figure>  
    
      </p>       </li> 
    </ol>
    
  </p>
 </exercise>

 <exercise>
  <p> Construct a graph to demonstrate each set of boundary conditions.
    <ol>
      <li><p> <m>u(1,\theta)=\sin\theta,0\lt\theta\lt\pi;u(r,0)=0,u(r,\pi),0\lt r\lt 1</m>    </p> </li>
      <li><p> <m>u(3,t)=200,t\gt 0; u(r,0)=\left\{\begin{array}{ll}300,\amp 0\lt r\lt 1\cr 200,\amp 1\lt r\lt 3\end{array}\right\}</m>  </p>  </li>
      <li><p> <m> \frac{\partial u}{\partial \theta}\bigg|_{\theta=0}=0, \frac{\partial u}{\partial \theta}\bigg|_{\theta=\pi}=0 ,0\lt r\lt 2; 
        u(2,\theta)=\left\{\begin{array}{ll}u_0,\amp 0\lt \theta\lt \frac{\pi}{2}\cr 0,\amp \frac{\pi}{2}\lt \theta\lt \pi\end{array}\right\}</m></p></li>
    </ol>   
  </p>
 </exercise>

 <exercise>
  <p> Consider the steady-state temperature <m>u(r,\theta)</m> that satisfies
    <md>
      \frac{\partial^2 u}{\partial r^2}+\frac{1}{r}\frac{\partial u}{\partial r}+\frac{1}{r^2}\frac{\partial^2 u}{\partial\theta^2}=0
    </md>
    Complete the following two parts for each set of boundary conditions.
    <ul>
      <li> <p> Derive the analytic solution <m>u(r,\theta).</m>    </p> </li>
      <li> <p> Create the graph of <m>u(r,\theta)</m> using either Mathematica or Jupyter Notebook on the specified domain.</p> </li>
    </ul>
    Consider the following two sets of boundary conditions separately:
    <ol>
      <li> <p> <m>u(1,\theta)=\theta, 0\lt \theta\lt 2\pi</m>      </p></li>
      <li> <p> <m>u(r,\beta)=0, 0\lt r\lt c; u(c,\theta)=f(\theta),0\lt\theta\lt\beta;u(r,0)=0,0\lt r\lt c</m>     </p></li>
    </ol>
  </p>
 </exercise>
</worksheet>
